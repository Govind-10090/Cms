{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role-based access control.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "role": { "type": "string", "enum": ["Manager", "Store Keeper"], "description": "Access role" },
        "displayName": { "type": "string", "description": "User display name" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Commodity product details.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique product ID" },
        "name": { "type": "string", "description": "Product name" },
        "category": { "type": "string", "description": "Product category" },
        "price": { "type": "number", "description": "Unit price" },
        "quantity": { "type": "number", "description": "Stock quantity" },
        "lastUpdated": { "type": "string", "format": "date-time", "description": "Last update timestamp" },
        "updatedBy": { "type": "string", "description": "UID of the user who last updated" }
      },
      "required": ["name", "category", "price", "quantity"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product inventory documents"
    }
  }
}
